# MongoDB Connection
MONGODB_URI=  ADD_MONGO_URI
MONGODB_DEFAULT_DB= ADD_MONGODB_NAME

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434

# Model Recommendations by PC spec:
#   Low-end   (4-6 GB RAM) : qwen2.5:3b  | llama3.2:3b
#   Mid-range (8 GB RAM)   : qwen2.5:7b  <- DEFAULT (best tool-use/size ratio)
#   Higher    (16 GB RAM)  : llama3.1:8b | mistral-nemo:12b
#   High-end  (24+ GB RAM) : qwen2.5:14b | deepseek-r1:14b
OLLAMA_MODEL=gpt-oss:120b-cloud

# MCP Server Transport
MCP_TRANSPORT=stdio

# Logging (DEBUG shows raw tool args, INFO is cleaner)
LOG_LEVEL=INFO

# Terminal UI - show tool call arguments inline (true/false)
SHOW_TOOL_ARGS=false

# Audit log - write structured JSON trail of every MCP tool call to logs/audit.log (true/false)
AUDIT_LOG_ENABLED=true

# Safety: Read-only mode - disables all write/destructive tools (true/false)
READ_ONLY=false

# Safety: Require confirmation for destructive ops like drop_database, drop_collection, delete_many (true/false)
CONFIRM_DESTRUCTIVE=true
